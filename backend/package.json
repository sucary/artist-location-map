{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:db:up": "docker-compose -f docker-compose.test.yml up -d",
    "test:db:down": "docker-compose -f docker-compose.test.yml down",
    "lint": "eslint src/**/*.ts",
    "dev": "nodemon src/server.ts",
    "db:init": "ts-node src/db/init.ts",
    "db:seed": "ts-node src/db/seed.ts",
    "db:seed-priority": "ts-node src/scripts/seed-priority-locations.ts",
    "db:refresh-cities": "ts-node src/scripts/refresh-city-boundaries.ts",
    "db:import-ocean": "ts-node src/scripts/import-ocean.ts",
    "db:setup": "npm run db:init && npm run db:import-ocean && npm run db:seed",
    "inspect:db": "ts-node src/tests/inspect-db.ts",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.95.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "pg": "^8.16.3",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/express-rate-limit": "^5.1.3",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "@types/shapefile": "^0.6.4",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "nodemon": "^3.1.11",
    "shapefile": "^0.6.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.0.16"
  }
